OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4-turbo-preview
AI_EMBEDDING_MODEL=text-embedding-3-small

DATABASE_URL=changeme_database_url

GITHUB_CLONE_TIMEOUT=300000
GITHUB_DEFAULT_BRANCH=main

MAX_ZIP_SIZE=52428800

TEMP_STORAGE_PATH=/tmp/codebase-wiki
CLEANUP_TTL=1800000
DOCS_STORAGE_PATH=/tmp/codebase-wiki-docs
VECTOR_INDEX_PATH=/tmp/codebase-wiki-index

ENCRYPTION_SECRET_KEY=your_32_char_secret_key_here_change_in_production

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here_change_in_production
